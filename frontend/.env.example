# ─────────────────────────────────────────────────────────
# Bower Ag CowCare Tool — Frontend Environment Variables
# Copy this to .env and fill in real values. NEVER commit .env
#
# For Vercel deployment: Set these in the Vercel Dashboard
# under Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────

# Supabase (public/anon key only — safe for frontend)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend API URL
# Development: http://localhost:8000
# Production:  https://bawashup-gpt-production.up.railway.app
VITE_API_URL=http://localhost:8000

# Application version (auto-set by CI or manual)
VITE_APP_VERSION=0.1.0-beta

# Sentry error monitoring (optional)
VITE_SENTRY_DSN=
