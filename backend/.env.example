# ─────────────────────────────────────────────────────────
# Bower Ag CowCare Tool — Backend Environment Variables
# Copy this to .env and fill in real values. NEVER commit .env
# ─────────────────────────────────────────────────────────

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (Claude API)
ANTHROPIC_API_KEY=

# Cloudflare R2 (S3-compatible object storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=bowerag-media

# Redis (for ARQ async job queue)
REDIS_URL=redis://localhost:6379

# Application
APP_VERSION=0.0.1
ENVIRONMENT=development
