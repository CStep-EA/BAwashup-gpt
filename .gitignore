# ─────────────────────────────────────────────────────────
# Bower Ag CowCare Tool — Git Ignore
# NEVER commit .env files, API keys, or node_modules
# ─────────────────────────────────────────────────────────

# Environment variables (CRITICAL — contains API keys)
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Vite / Frontend build
frontend/dist/
frontend/.vite/
*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Testing
coverage/
htmlcov/
.coverage

# Logs
*.log
logs/

# Migration reports (generated at runtime)
backend/scripts/migration_reports/

# Advisory PDF documents (large binaries — generated at runtime)
backend/docs/advisory/
backend/data/advisory_docs/

# Temporary files
/tmp/
*.tmp

# Supabase local
.supabase/

# Sentry
.sentryclirc
